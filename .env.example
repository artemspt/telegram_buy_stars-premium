# Telegram bot token from @BotFather -> /newbot.
# Format: digits:letters, example: 123456789:AA...
BOT_TOKEN=replace_with_bot_token

# Telegram numeric user ID of bot administrator.
# Get via @userinfobot or @getmyidbot.
ADMIN_ID=123456789

# Telegram username for support contact (with or without @).
# Example: support
ADMIN_USERNAME=support

# PostgreSQL connection host.
# Local dev: localhost, Docker: service name (for example: postgres).
DB_HOST=localhost

# PostgreSQL port (default 5432).
DB_PORT=5432

# PostgreSQL database name (must already exist or be created by your setup).
DB_NAME=bystars_db

# PostgreSQL username with access to DB_NAME.
DB_USER=postgres

# PostgreSQL password for DB_USER.
DB_PASSWORD=replace_with_db_password

# TON API key from https://tonapi.io (create account -> API keys).
TON_API_KEY=replace_with_tonapi_key

# 24-word TON wallet seed phrase as JSON array of strings.
# Source: your TON wallet export/recovery phrase.
WALLET_MNEMONIC=["word1","word2","word3","word4","word5","word6","word7","word8","word9","word10","word11","word12","word13","word14","word15","word16","word17","word18","word19","word20","word21","word22","word23","word24"]

# API key to protect FastAPI endpoints (/v1/*) from external calls.
# Generate a long random string (for example: python -c "import secrets; print(secrets.token_urlsafe(48))")
API_KEY=replace_with_internal_api_key

# FastAPI bind host. Use 0.0.0.0 for Docker/server, 127.0.0.1 for local-only.
SERVER__HOST=0.0.0.0

# FastAPI port.
SERVER__PORT=8000

# Auto-reload server code on changes (development only).
# true for local dev, false for production.
SERVER__RELOAD=true

# Log verbosity: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# Path to Fragment session file generated by app.
# Keep inside project and DO NOT commit to git.
FRAGMENT_SESSION_PATH=fragment_api/fragment_session.json
